[Unit]
Description=GNBSim iptables rules
After=network-online.target gnbsim-macvlan.service sys-subsystem-net-devices-gnbaccess.device
Wants=network-online.target sys-subsystem-net-devices-gnbaccess.device

[Service]
Type=oneshot
ExecStart=/bin/sh -c '/usr/sbin/iptables-restore -n < /etc/iptables/gnbsim-rules.v4'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
