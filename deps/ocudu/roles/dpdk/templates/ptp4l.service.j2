[Unit]
Description=PTP Boundary/Ordinary Clock - free-run grandmaster
Wants=network-online.target
After=network-online.target
StartLimitIntervalSec=0

[Service]
ExecStart=/usr/sbin/ptp4l -f /etc/linuxptp/ptp_gm.conf -2 -i {{ pf_iface }} -m
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
